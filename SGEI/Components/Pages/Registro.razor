@page "/registro"
@using SGEI.Models
@using SGEI.Services
@using Microsoft.AspNetCore.Components.Forms
@inject AuthService AuthService
@inject NavigationManager Nav
@rendermode InteractiveServer

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0 p-4" style="border-radius: 20px;">
                <div class="text-center mb-4">
                    <h3 class="title-estetica fw-bold">Criar Conta</h3>
                    <p class="text-muted">Preencha seus dados para começar.</p>
                </div>

                @* Trocamos o form pelo EditForm para validar as DataAnnotations da sua Model *@
                <EditForm Model="novoCliente" OnValidSubmit="EfetuarCadastro">
                    <DataAnnotationsValidator />

                    <div class="mb-3">
                        <label class="form-label fw-medium text-muted">Nome Completo</label>
                        <InputText class="form-control custom-input" @bind-Value="novoCliente.Nome" placeholder="Digite seu nome" />
                        <ValidationMessage For="@(() => novoCliente.Nome)" class="text-danger small" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-medium text-muted">E-mail</label>
                        <InputText type="email" class="form-control custom-input" @bind-Value="novoCliente.Email" placeholder="seu@email.com" />
                        <ValidationMessage For="@(() => novoCliente.Email)" class="text-danger small" />
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-medium text-muted">Telefone / WhatsApp</label>
                        <InputText class="form-control custom-input" @bind-Value="novoCliente.Telefone" placeholder="(00) 00000-0000" />
                        <ValidationMessage For="@(() => novoCliente.Telefone)" class="text-danger small" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-medium text-muted">Senha</label>
                        <div class="input-group">
                            <InputText type="@(mostrarSenha ? "text" : "password")" class="form-control custom-input" @bind-Value="novoCliente.Senha" style="border-right: none;" />
                            <button type="button" class="input-group-text bg-white" @onclick="() => mostrarSenha = !mostrarSenha" style="border-radius: 0 12px 12px 0; border: 1px solid #eee; border-left: none;">
                                @(mostrarSenha ? "👁️" : "👁️‍🗨️")
                            </button>
                        </div>
                        <ValidationMessage For="@(() => novoCliente.Senha)" class="text-danger small" />
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-medium text-muted">Confirmar Senha</label>
                        <div class="input-group">
                            <InputText type="@(mostrarConfirmacao ? "text" : "password")" class="form-control custom-input" @bind-Value="confirmacaoSenha" style="border-right: none;" />
                            <button type="button" class="input-group-text bg-white" @onclick="() => mostrarConfirmacao = !mostrarConfirmacao" style="border-radius: 0 12px 12px 0; border: 1px solid #eee; border-left: none;">
                                @(mostrarConfirmacao ? "👁️" : "👁️‍🗨️")
                            </button>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(mensagem))
                    {
                        <div class="alert @(mensagem == "Sucesso" ? "alert-success" : "alert-danger") text-center mb-3" style="border-radius: 12px; padding: 10px;">
                            @(mensagem == "Sucesso" ? "Conta criada! Redirecionando..." : mensagem)
                        </div>
                    }

                    <button type="submit" class="btn-login w-100 mb-3" disabled="@isProcessando">
                        @if (isProcessando) { <span class="spinner-border spinner-border-sm me-2"></span> }
                        Cadastrar e Entrar
                    </button>

                    <div class="text-center mt-3">
                        <span class="text-muted">Já tem uma conta?</span>
                        <a href="/login" class="text-decoration-none fw-bold" style="color: #EAA3B5;">Faça Login</a>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>

<style>
    /* Estilos preservados do seu layout original */
    .title-estetica { color: #EAA3B5; }
    .custom-input { border-radius: 12px; border: 1px solid #eee; padding: 12px; box-shadow: none !important; }
    .custom-input:focus { border-color: #EAA3B5; }
    .btn-login { background: #EAA3B5; color: white; border: none; padding: 12px; border-radius: 50px; font-weight: bold; font-size: 1.1rem; transition: 0.3s; }
    .btn-login:hover:not(:disabled) { background: #d892a4; transform: translateY(-2px); }
    .btn-login:disabled { opacity: 0.7; cursor: not-allowed; }
</style>

@code {
    private Cliente novoCliente = new();
    private string confirmacaoSenha = "";
    private string mensagem = "";
    private bool isProcessando = false;

    private bool mostrarSenha = false;
    private bool mostrarConfirmacao = false;

    private async Task EfetuarCadastro()
    {
        if (novoCliente.Senha != confirmacaoSenha)
        {
            mensagem = "As senhas não coincidem. Tente novamente.";
            return;
        }

        isProcessando = true;
        mensagem = "";

        // O método já recebe o objeto com 'Ativo' e 'DataCadastro' preenchidos por padrão
        mensagem = await AuthService.CadastrarClienteAsync(novoCliente);

        if (mensagem == "Sucesso")
        {
            StateHasChanged();
            await Task.Delay(1500); 
            Nav.NavigateTo("/login");
        }
        else
        {
            isProcessando = false;
        }
    }
}