@page "/login"
@using SGEI.Services
@using SGEI.Models.DTO
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthService AuthService
@inject UserSession Session
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@rendermode InteractiveServer

<div class="login-container">
    <div class="login-card">
        <h2 class="auth-title">Entrar</h2>
        <p class="auth-subtitle">Acesse sua conta para gerenciar seus horários.</p>

        @* Trocamos o form pelo EditForm para usar as validações do LoginDTO *@
        <EditForm Model="loginModel" OnValidSubmit="EfetuarLogin" class="mt-4">
            <DataAnnotationsValidator />

            <div class="input-group-minimal mb-3">
                <label>E-mail</label>
                <InputText @bind-Value="loginModel.Email" placeholder="exemplo@email.com" class="form-control" />
                <ValidationMessage For="@(() => loginModel.Email)" class="text-danger small" />
            </div>

            <div class="input-group-minimal mb-4">
                <label>Senha</label>
                <div class="password-wrapper">
                    <InputText type="@tipoCampo" @bind-Value="loginModel.Senha" placeholder="••••••••" class="form-control" />
                    <button type="button" class="btn-eye" @onclick="ToggleSenha">
                        <i class="bi @(mostrarSenha ? "bi-eye-slash" : "bi-eye")"></i>
                    </button>
                </div>
                <ValidationMessage For="@(() => loginModel.Senha)" class="text-danger small" />
            </div>

            @if (!string.IsNullOrEmpty(mensagemErro))
            {
                <div class="auth-alert mb-3">
                    <i class="bi bi-exclamation-circle"></i> @mensagemErro
                </div>
            }

            <button type="submit" class="btn-auth-primary w-100" disabled="@isProcessando">
                @if (isProcessando)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                }
                Acessar Sistema
            </button>
        </EditForm>

        <div class="auth-footer mt-4">
            <span>Não tem uma conta?</span>
            <a href="/registro">Criar agora</a>
        </div>
    </div>
</div>

<style>
    /* Mantive seu CSS original conforme solicitado */
    .login-container { display: flex; justify-content: center; align-items: center; min-height: 70vh; }
    .login-card { background: white; padding: 2.5rem; border-radius: 24px; box-shadow: 0 10px 40px rgba(0,0,0,0.02); width: 100%; max-width: 400px; }
    .auth-title { font-weight: 700; font-size: 1.8rem; color: #111; margin-bottom: 0.5rem; }
    .auth-subtitle { color: #888; font-size: 0.9rem; }
    .input-group-minimal label { display: block; font-size: 0.8rem; font-weight: 600; color: #555; margin-bottom: 8px; }
    
    /* Pequeno ajuste para o InputText do Blazor */
    .input-group-minimal .form-control { width: 100%; border: 1px solid #eee; padding: 12px 16px; border-radius: 12px; transition: 0.3s; outline: none; }
    .input-group-minimal .form-control:focus { border-color: #EAA3B5; background: #fffdfd; box-shadow: none; }

    .password-wrapper { position: relative; }
    .btn-eye { position: absolute; right: 12px; top: 50%; transform: translateY(-50%); border: none; background: none; color: #aaa; cursor: pointer; }
    .auth-alert { background: #FFF5F5; color: #C53030; padding: 12px; border-radius: 10px; font-size: 0.85rem; font-weight: 500; display: flex; align-items: center; gap: 8px; }
    .btn-auth-primary { background: #111; color: white; border: none; padding: 14px; border-radius: 12px; font-weight: 600; transition: 0.3s; }
    .btn-auth-primary:hover:not(:disabled) { background: #EAA3B5; transform: translateY(-2px); }
    .btn-auth-primary:disabled { opacity: 0.7; cursor: not-allowed; }
    .auth-footer { text-align: center; font-size: 0.9rem; }
    .auth-footer a { color: #EAA3B5; font-weight: 600; text-decoration: none; }
</style>

@code {
    private LoginDTO loginModel = new(); 
    private string mensagemErro = "";
    private bool isProcessando = false;
    private bool mostrarSenha = false;
    private string tipoCampo => mostrarSenha ? "text" : "password";

    private void ToggleSenha() => mostrarSenha = !mostrarSenha;

    private async Task EfetuarLogin()
    {
        isProcessando = true;
        mensagemErro = "";
        
        // Chamamos o serviço usando os dados do DTO
        var usuario = await AuthService.FazerLoginAsync(loginModel.Email, loginModel.Senha);
        
        if (usuario != null)
        {
            var customAuthStateProvider = (SimpleAuthStateProvider)AuthStateProvider;
            customAuthStateProvider.MarcarComoLogado(usuario);
            Session.UsuarioLogado = usuario;
            
            Nav.NavigateTo(usuario.Role == "Admin" ? "/admin/dashboard" : "/agendar");
        }
        else
        {
            mensagemErro = "E-mail ou senha incorretos. Tente novamente.";
            isProcessando = false;
        }
    }
}