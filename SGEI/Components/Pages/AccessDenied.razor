@page "/acesso-negado"

<div class="denied-container">
    <div class="denied-card text-center">
        <div class="icon-box mb-4">
            <i class="bi bi-shield-lock-fill"></i>
        </div>
        <h2 class="fw-bold mb-3">Acesso Restrito</h2>
        <p class="text-muted mb-4">
            Desculpe, mas você não tem permissão para acessar esta área.<br>
            Esta página é reservada apenas para administradores.
        </p>
        <a href="/" class="btn-back">Voltar para o Início</a>
    </div>
</div>

<style>
    .denied-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 70vh;
        font-family: 'Poppins', sans-serif;
    }

    .denied-card {
        background: white;
        padding: 3rem;
        border-radius: 24px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.02);
        max-width: 450px;
    }

    .icon-box {
        font-size: 4rem;
        color: #EAA3B5; /* Rosa da estética */
        animation: pulse 2s infinite;
    }

    .btn-back {
        background: #111;
        color: white;
        text-decoration: none;
        padding: 12px 30px;
        border-radius: 12px;
        font-weight: 600;
        display: inline-block;
        transition: 0.3s;
    }

    .btn-back:hover {
        background: #EAA3B5;
        color: white;
        transform: translateY(-2px);
    }

    @@keyframes pulse {
        0% { transform: scale(1); opacity: 1; }
        50% { transform: scale(1.05); opacity: 0.8; }
        100% { transform: scale(1); opacity: 1; }
    }
</style>