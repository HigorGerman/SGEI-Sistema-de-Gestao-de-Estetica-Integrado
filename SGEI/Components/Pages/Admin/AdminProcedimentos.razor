@page "/admin/procedimentos"
@using SGEI.Models
@using SGEI.Services
@inject ProcedimentoService Service
@inject UserSession Session
@inject NavigationManager Nav
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@inject IJSRuntime JS

<PageTitle>Gestão de Serviços - SGEI</PageTitle>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="title-estetica mb-0">Gestão de Procedimentos</h3>
    </div>

    @if (Session.UsuarioLogado?.Role == "Admin")
    {
        <div class="admin-card mb-5 p-4">
            <h5 class="fw-bold mb-3" style="color: #555;">
                @(editando ? "📝 Editando Procedimento" : "✨ Novo Procedimento")
            </h5>
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="fw-medium text-muted mb-2">Nome do Serviço</label>
                    <input type="text" @bind="novoProc.Nome" class="form-control custom-input" placeholder="Ex: Limpeza de Pele" />
                </div>
                <div class="col-md-3">
                    <label class="fw-medium text-muted mb-2">Preço (R$)</label>
                    <input type="number" @bind="novoProc.Preco" class="form-control custom-input" step="0.01" />
                </div>
                <div class="col-md-3">
                    <label class="fw-medium text-muted mb-2">Duração (Min)</label>
                    <input type="number" @bind="novoProc.DuracaoMinutos" class="form-control custom-input" />
                </div>
                <div class="col-12">
                    <label class="fw-medium text-muted mb-2">Descrição do Serviço</label>
                    <textarea @bind="novoProc.Descricao" class="form-control custom-input" rows="2" placeholder="Descreva os benefícios..."></textarea>
                </div>
                <div class="col-12 mt-3 d-flex gap-2">
                    <button class="btn-salvar-admin w-100" @onclick="Salvar">
                        @(editando ? "💾 Salvar Alterações" : "✨ Cadastrar Procedimento")
                    </button>
                    @if (editando)
                    {
                        <button class="btn btn-outline-secondary rounded-pill px-4" @onclick="CancelarEdicao">Cancelar</button>
                    }
                </div>
            </div>
            
            @if (!string.IsNullOrEmpty(mensagem))
            {
                <div class="alert @(mensagem.Contains("Erro") ? "alert-danger" : "alert-success") mt-3 text-center" style="border-radius: 12px;">
                    @mensagem
                </div>
            }
        </div>

        <div class="admin-card p-4">
            <h5 class="fw-bold mb-3" style="color: #555;">Serviços Ativos</h5>
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr style="border-bottom: 2px solid #fff0f3;">
                            <th>Nome</th>
                            <th>Preço</th>
                            <th>Duração</th>
                            <th class="text-center">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in procedimentos)
                        {
                            <tr @key="p.Id">
                                <td>
                                    <div class="fw-bold">@p.Nome</div>
                                    <div class="text-muted small">@p.Descricao</div>
                                </td>
                                <td class="text-pink">@p.Preco.ToString("C")</td>
                                <td><span class="badge bg-light text-dark">@p.DuracaoMinutos min</span></td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-outline-primary border-0 me-2" @onclick="() => PrepararEdicao(p)">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger border-0" @onclick="() => Excluir(p.Id)">
                                        <i class="bi bi-trash3-fill"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<style>
    .title-estetica { color: #EAA3B5; font-weight: 700; }
    .admin-card { background: white; border-radius: 20px; box-shadow: 0 4px 20px rgba(0,0,0,0.05); border: none; }
    .custom-input { border-radius: 12px; border: 1px solid #eee; padding: 12px; transition: 0.3s; }
    .btn-salvar-admin { background-color: #EAA3B5; color: white; border: none; padding: 14px; border-radius: 50px; font-weight: bold; transition: 0.3s; }
    .btn-salvar-admin:hover { background-color: #d892a4; transform: translateY(-2px); }
    .text-pink { color: #EAA3B5; font-weight: bold; }
</style>

@code {
    private List<Procedimento> procedimentos = new();
    private Procedimento novoProc = new();
    private string mensagem = "";
    private bool editando = false;

    protected override async Task OnInitializedAsync()
    {
        if (Session.UsuarioLogado?.Role != "Admin")
        {
            Nav.NavigateTo("/");
            return;
        }
        await Carregar();
    }

    private async Task Carregar() => procedimentos = await Service.ListarTodosAsync();

    private void PrepararEdicao(Procedimento p)
    {
        // Criamos um novo objeto para o formulário para isolar a edição da tabela
        novoProc = new Procedimento
        {
            Id = p.Id, 
            Nome = p.Nome,
            Preco = p.Preco,
            DuracaoMinutos = p.DuracaoMinutos,
            Descricao = p.Descricao
        };
        editando = true;
        mensagem = "";
    }

    private void CancelarEdicao() { novoProc = new(); editando = false; }

    private async Task Salvar()
    {
        if (!string.IsNullOrWhiteSpace(novoProc.Nome))
        {
            var sucesso = await Service.SalvarProcedimentoAsync(novoProc);
            if (sucesso)
            {
                mensagem = editando ? "✅ Procedimento atualizado!" : "✅ Procedimento cadastrado!";
                novoProc = new();
                editando = false;
                await Carregar();
            }
            else
            {
                mensagem = "❌ Erro ao salvar. Verifique o console.";
            }

            StateHasChanged();
            await Task.Delay(3000);
            mensagem = "";
            StateHasChanged();
        }
    }

    private async Task Excluir(int id)
    {
        // Confirmação simples para evitar exclusão acidental
        var confirmado = await JS.InvokeAsync<bool>("confirm", "Tem certeza que deseja excluir este procedimento? Isso pode afetar agendamentos existentes.");
        
        if (confirmado)
        {
            await Service.ExcluirProcedimentoAsync(id);
            await Carregar();
        }
    }
}}