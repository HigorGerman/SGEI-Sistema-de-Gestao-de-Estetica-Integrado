@page "/admin/dashboard"
@using SGEI.Models
@using SGEI.Services
@inject AgendamentoService AgendamentoService
@inject UserSession Session
@inject NavigationManager Nav
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]

<div class="container-fluid py-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="title-estetica mb-0">Visão Geral da Clínica</h3>
        <span class="text-muted fw-bold">Hoje é @DateTime.Now.ToString("dd/MM/yyyy")</span>
    </div>

    @if (carregando)
    {
        <div class="text-center p-5">
            <div class="spinner-border" style="color: #EAA3B5;" role="status"></div>
        </div>
    }
    else if (resumo != null)
    {
        <div class="row mb-4">
            <div class="col-md-3 mb-3">
                <div class="card shadow-sm border-0 h-100" style="border-radius: 15px; border-left: 5px solid #EAA3B5 !important;">
                    <div class="card-body">
                        <h6 class="text-muted fw-bold text-uppercase mb-1">Agendamentos (Hoje)</h6>
                        <h2 class="mb-0 fw-bold text-dark">@resumo.AgendamentosHoje</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card shadow-sm border-0 h-100" style="border-radius: 15px; border-left: 5px solid #28a745 !important;">
                    <div class="card-body">
                        <h6 class="text-muted fw-bold text-uppercase mb-1">Faturamento Previsto (Hoje)</h6>
                        <h2 class="mb-0 fw-bold text-dark">R$ @resumo.FaturamentoHoje.ToString("N2")</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card shadow-sm border-0 h-100" style="border-radius: 15px; border-left: 5px solid #17a2b8 !important;">
                    <div class="card-body">
                        <h6 class="text-muted fw-bold text-uppercase mb-1">Agendamentos (Mês)</h6>
                        <h2 class="mb-0 fw-bold text-dark">@resumo.AgendamentosMes</h2>
                    </div>
                </div>
            </div>
            <div class="col-md-3 mb-3">
                <div class="card shadow-sm border-0 h-100" style="border-radius: 15px; border-left: 5px solid #ffc107 !important;">
                    <div class="card-body">
                        <h6 class="text-muted fw-bold text-uppercase mb-1">Faturamento Previsto (Mês)</h6>
                        <h2 class="mb-0 fw-bold text-dark">R$ @resumo.FaturamentoMes.ToString("N2")</h2>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-8 mb-4">
                <div class="card shadow-sm border-0" style="border-radius: 15px;">
                    <div class="card-header bg-white border-0 pt-4 pb-0">
                        <h5 class="fw-bold" style="color: #555;">Próximas Clientes de Hoje</h5>
                    </div>
                    <div class="card-body">
                        @if (!resumo.ProximosAtendimentos.Any())
                        {
                            <div class="alert alert-light text-center rounded-3">Nenhum atendimento pendente para o resto do dia.</div>
                        }
                        else
                        {
                            <ul class="list-group list-group-flush">
                                @foreach (var ag in resumo.ProximosAtendimentos)
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-3">
                                        <div class="d-flex align-items-center">
                                            <div class="bg-light rounded-circle p-3 me-3 text-center" style="width: 60px; height: 60px;">
                                                <span class="fw-bold" style="color: #EAA3B5;">@ag.DataHora.ToString("HH:mm")</span>
                                            </div>
                                            <div>
                                                <h6 class="mb-0 fw-bold">@(ag.Cliente?.Nome ?? "Cliente")</h6>
                                                <small class="text-muted">@ag.Procedimento?.Nome</small>
                                            </div>
                                        </div>
                                        <span class="badge bg-warning text-dark rounded-pill">Pendente</span>
                                    </li>
                                }
                            </ul>
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="card shadow-sm border-0 h-100" style="border-radius: 15px;">
                    <div class="card-body d-flex flex-column justify-content-center text-center p-4">
                        <h5 class="fw-bold mb-4" style="color: #555;">Desempenho Diário</h5>
                        
                        @{
                            decimal metaDiaria = 500m;
                            decimal porcentagem = (resumo.FaturamentoHoje / metaDiaria) * 100;
                            if (porcentagem > 100) porcentagem = 100;
                        }
                        
                        <div class="mb-3">
                            <span class="fs-1 fw-bold" style="color: #EAA3B5;">@(porcentagem.ToString("N0"))%</span>
                            <span class="d-block text-muted">da meta diária (R$ @metaDiaria)</span>
                        </div>

                        <div class="progress" style="height: 20px; border-radius: 10px;">
                            <div class="progress-bar progress-bar-striped progress-bar-animated" 
                                 role="progressbar" 
                                 style="width: @porcentagem.ToString("N0").Replace(",",".")%; background-color: #EAA3B5;" 
                                 aria-valuenow="@porcentagem" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .title-estetica { color: #EAA3B5; font-weight: bold; }
</style>

@code {
    private DashboardResumo resumo;
    private bool carregando = true;

    protected override async Task OnInitializedAsync()
    {
        // Trava de segurança para garantir que apenas o Admin veja o faturamento
        if (Session.UsuarioLogado == null || Session.UsuarioLogado.Role != "Admin")
        {
            Nav.NavigateTo("/");
            return;
        }

        resumo = await AgendamentoService.ObterResumoDashboardAsync();
        carregando = false;
    }
}