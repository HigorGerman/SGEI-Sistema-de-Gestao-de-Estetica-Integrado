@using Microsoft.AspNetCore.Components.Authorization

<Router AppAssembly="@typeof(Program).Assembly">
    <Found Context="routeData">
        @* Trocamos o RouteView pelo AuthorizeRouteView para habilitar o bloqueio por Roles *@
        <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(SGEI.Components.Layout.MainLayout)">
            
            @* Caso o usuário tente entrar em uma página @attribute [Authorize] sem estar logado *@
            <NotAuthorized>
                @if (context.User.Identity?.IsAuthenticated != true)
                {
                    @* Se não está logado, manda pro Login *@
                    <RedirectToLogin />
                }
                else
                {
                    @* Se está logado mas não tem a Role (ex: Cliente tentando entrar no Admin) *@
                    <div class="container py-5 text-center">
                        <h3 class="text-danger fw-bold">Acesso Negado</h3>
                        <p class="text-muted">Você não tem permissão para acessar esta área.</p>
                        <a href="/" class="btn btn-outline-dark rounded-pill">Voltar ao Início</a>
                    </div>
                }
            </NotAuthorized>

            @* Enquanto o Blazor verifica as permissões *@
            <Authorizing>
                <div class="text-center py-5">
                    <div class="spinner-border text-pink" role="status"></div>
                    <p class="mt-2 text-muted">Verificando permissões...</p>
                </div>
            </Authorizing>

        </AuthorizeRouteView>
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <LayoutView Layout="@typeof(SGEI.Components.Layout.MainLayout)">
            <div class="container py-5 text-center">
                <h2 class="fw-bold">404</h2>
                <p class="text-muted">Desculpe, não há nada neste endereço.</p>
                <a href="/" class="btn btn-primary rounded-pill">Início</a>
            </div>
        </LayoutView>
    </NotFound>
</Router>